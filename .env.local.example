# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase Postgres
# On Vercel, the Supabase integration injects POSTGRES_URL automatically —
# nothing to set there. For local dev, paste the connection string from
# Supabase → Settings → Database (use the transaction pooler URL).
DATABASE_URL=postgresql://postgres...@...pooler.supabase.com:6543/postgres

# Uploadthing
UPLOADTHING_TOKEN=...

# Ably (real-time client <> agency messaging)
ABLY_API_KEY=...

# GoHighLevel (agency CRM — revenue, billing, pipeline sync)
GHL_API_KEY=...
GHL_LOCATION_ID=...
GHL_WEBHOOK_SECRET=...
